{
  "name": "@naktal/crawler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "crawl:ann": "ts-node src/index.ts --type announcement --pages 10",
    "crawl:result": "ts-node src/index.ts --type bid-result --pages 10",
    "crawl:fill-sub": "ts-node src/index.ts --type fill-sub",
    "crawl:all": "ts-node src/index.ts --type all --pages 10 && ts-node src/index.ts --type fill-sub",
    "bulk:import": "ts-node src/bulk-import.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "@types/pg": "^8.20.0",
    "decimal.js": "^10.4.3",
    "pg": "^8.20.0",
    "pg-copy-streams": "^7.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/pg-copy-streams": "^1.2.5",
    "ts-node": "^10.9.2",
    "typescript": "5.9.2"
  }
}
