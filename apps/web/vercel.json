{
  "buildCommand": "cd ../.. && pnpm turbo build --filter=web",
  "outputDirectory": ".next",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "framework": "nextjs",
  "functions": {
    "api/ml-predict.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 15,
      "memory": 1024
    }
  },
  "crons": [
    { "path": "/api/cron/sync-g2b", "schedule": "0 0 * * *" }
  ]
}
