generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String                 @id @default(cuid())
  supabaseId      String                 @unique
  bizNo           String                 @unique
  bizName         String
  ownerName       String
  notifyEmail     String?
  notifyPhone     String?
  plan            Plan                   @default(FREE)
  isAdmin         Boolean                @default(false)
  isActive        Boolean                @default(true)
  adminMemo       String?
  createdAt       DateTime               @default(now())
  subscription    Subscription?
  alerts          UserAlert[]
  companyProfile  CompanyProfile?
  recommendations NumberRecommendation[]
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  plan             Plan
  portoneOrderId   String?   @unique
  portonePaymentId String?   @unique
  status           SubStatus @default(ACTIVE)
  currentPeriodEnd DateTime
  createdAt        DateTime  @default(now())
}

model UserAlert {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  keywords   String[]
  categories String[]
  regions    String[]
  minBudget  BigInt?
  maxBudget  BigInt?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Announcement {
  id                   String                @id @default(cuid())
  konepsId             String                @unique
  title                String
  orgName              String
  budget               BigInt
  deadline             DateTime
  category             String
  region               String
  rawJson              Json
  isPinned             Boolean               @default(false)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  participantSnapshots ParticipantSnapshot[]
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String
  before    Json?
  after     Json?
  reason    String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
}

model BidResult {
  id         String   @id @default(cuid())
  annId      String   @unique
  bidRate    Decimal  @db.Decimal(10, 4)
  finalPrice BigInt
  numBidders Int
  createdAt  DateTime @default(now())
}

model CrawlLog {
  id        String      @id @default(cuid())
  type      CrawlType
  status    CrawlStatus
  count     Int         @default(0)
  errors    String?
  createdAt DateTime    @default(now())
}

model Prediction {
  id        String   @id @default(cuid())
  type      String
  cacheKey  String   @unique
  result    Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([cacheKey])
  @@index([expiresAt])
}

// B안 신규 모델

model CompanyProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  bizName             String
  mainCategory        String
  subCategories       String[]
  constructionRecords Json[]
  creditScore         String?
  capitalAmount       BigInt?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

model NumberRecommendation {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  annId            String?
  category         String
  budgetRange      String
  region           String
  estimatedBidders Int?
  combo1           Int[]
  combo2           Int[]
  combo3           Int[]
  hitRate1         Float
  hitRate2         Float
  hitRate3         Float
  sampleSize       Int
  modelVersion     String
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
}

model NumberSelectionStat {
  id           String   @id @default(cuid())
  category     String
  budgetRange  String
  region       String
  bidderRange  String   // "1-5" | "6-10" | "11-20" | "21-50" | "51+"
  rateInt      Int      // 투찰률 × 1000 (예: 87345 = 87.345%)
  winCount     Int      @default(0)
  totalCount   Int      @default(0)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([category, budgetRange, region, bidderRange, rateInt])
  @@index([category, budgetRange, region, bidderRange])
}

model ParticipantSnapshot {
  id           String       @id @default(cuid())
  annId        String
  announcement Announcement @relation(fields: [annId], references: [id])
  count        Int
  snapshotAt   DateTime     @default(now())

  @@index([annId, snapshotAt])
}

enum Plan {
  FREE
  STANDARD
  PRO
}

enum SubStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum CrawlType {
  ANNOUNCEMENT
  BID_RESULT
  HIST_CURSOR
}

enum CrawlStatus {
  SUCCESS
  PARTIAL
  FAILED
}
