generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String                 @id @default(cuid())
  supabaseId      String                 @unique
  bizNo           String                 @unique
  bizName         String
  ownerName       String
  notifyEmail     String?
  notifyPhone     String?
  plan            Plan                   @default(FREE)
  isAdmin         Boolean                @default(false)
  isActive        Boolean                @default(true)
  adminMemo       String?
  createdAt       DateTime               @default(now())
  subscription    Subscription?
  alerts          UserAlert[]
  companyProfile  CompanyProfile?
  recommendations NumberRecommendation[]
  bidOutcomes     BidOutcome[]
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  plan             Plan
  portoneOrderId   String?   @unique
  portonePaymentId String?   @unique
  status           SubStatus @default(ACTIVE)
  currentPeriodEnd DateTime
  createdAt        DateTime  @default(now())
}

model UserAlert {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  keywords   String[]
  categories String[]
  regions    String[]
  minBudget  BigInt?
  maxBudget  BigInt?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Announcement {
  id                   String                @id @default(cuid())
  konepsId             String                @unique
  title                String
  orgName              String
  budget               BigInt
  deadline             DateTime
  category             String
  region               String
  rawJson              Json
  subCategories        String[]              @default([])
  aValueYn             String                @default("")
  aValueAmt            BigInt                @default(0)
  aValueTotal          BigInt                @default(0)
  isPinned             Boolean               @default(false)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  participantSnapshots ParticipantSnapshot[]
  bidPricePrediction   BidPricePrediction?
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String
  before    Json?
  after     Json?
  reason    String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
}

model BidResult {
  id          String   @id @default(cuid())
  annId       String   @unique
  bidRate     Decimal  @db.Decimal(10, 4)
  finalPrice  BigInt
  numBidders  Int
  winnerName  String?
  createdAt   DateTime @default(now())
}

model CrawlLog {
  id        String      @id @default(cuid())
  type      CrawlType
  status    CrawlStatus
  count     Int         @default(0)
  errors    String?
  createdAt DateTime    @default(now())
}

model Prediction {
  id        String   @id @default(cuid())
  type      String
  cacheKey  String   @unique
  result    Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([cacheKey])
  @@index([expiresAt])
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique   // format: "userId:feature" or "ip:endpoint"
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt
}

// B안 신규 모델

model CompanyProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])

  // 사업자 기본정보
  bizNo               String?  // 사업자등록번호 10자리 (G2B 연동 키)
  bizName             String
  ceoName             String?  // 대표자명
  address             String?  // 소재지
  establishedAt       String?  // 설립일 YYYYMMDD
  employeeCount       Int?     // 임직원 수

  // 업종
  mainCategory        String
  subCategories       String[]

  // 면허/자격요건 [{licenseType, licenseNo, registAt, gradeNm, validYn}]
  licenses            Json[]

  // 재무
  capitalAmount       BigInt?
  creditScore         String?

  // 시공 실적 [{year, projectName, amount, client, contractDate, completionDate, category}]
  constructionRecords Json[]

  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

model NumberRecommendation {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  annId            String?
  category         String
  budgetRange      String
  region           String
  estimatedBidders Int?
  combo1           Int[]
  combo2           Int[]
  combo3           Int[]
  hitRate1         Float
  hitRate2         Float
  hitRate3         Float
  sampleSize       Int
  modelVersion     String
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
}

model NumberSelectionStat {
  id           String   @id @default(cuid())
  category     String
  budgetRange  String
  region       String
  bidderRange  String   // "1-5" | "6-10" | "11-20" | "21-50" | "51+"
  rateInt      Int      // 투찰률 × 1000 (예: 87345 = 87.345%)
  winCount     Int      @default(0)
  totalCount   Int      @default(0)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([category, budgetRange, region, bidderRange, rateInt])
  @@index([category, budgetRange, region, bidderRange])
}

model BidOutcome {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  annId            String
  recommendationId String?
  selectedNos      Int[]
  bidRate          Decimal       @db.Decimal(10, 4)
  bidPrice         BigInt?                         // 실제 투찰금액 (원) — CORE 1 피드백
  result           OutcomeResult @default(PENDING)
  finalWinningNos  Int[]
  actualBidRate    Decimal?      @db.Decimal(10, 4)
  actualFinalPrice BigInt?                         // 실제 낙찰금액 (원)
  actualSajungRate Decimal?      @db.Decimal(8, 4) // 실제 사정율 % — CORE 1 정확도 측정
  numBidders       Int?
  recommendHit     Boolean?
  bidAt            DateTime
  openedAt         DateTime?
  bonusGranted     Boolean       @default(false)
  createdAt        DateTime      @default(now())

  @@index([userId, bidAt])
  @@index([annId])
}

model OrgBiddingPattern {
  id         String   @id @default(cuid())
  orgName    String
  freqMap    Json
  deviation  Json
  sampleSize Int
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([orgName])
  @@index([orgName])
}

model ParticipantSnapshot {
  id           String       @id @default(cuid())
  annId        String
  announcement Announcement @relation(fields: [annId], references: [id])
  count        Int
  snapshotAt   DateTime     @default(now())

  @@index([annId, snapshotAt])
}

// ─── 빅데이터 분석 고도화 모델 ─────────────────────────────────────────────────

model SajungRateStat {
  id          String   @id @default(cuid())
  orgName     String   // 'ALL' = 전체 평균 폴백
  category    String
  budgetRange String
  region      String
  avg         Float
  stddev      Float
  p25         Float
  p50         Float
  p75         Float
  min         Float
  max         Float
  mode        Float
  monthlyAvg  Json     // { "1": 98.7, ..., "12": 98.8 }
  sampleSize  Int
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([orgName, category, budgetRange, region])
  @@index([orgName, category, budgetRange, region])
}

model BidPricePrediction {
  id                  String       @id @default(cuid())
  annId               String       @unique
  announcement        Announcement @relation(fields: [annId], references: [id])
  predictedSajungRate Float
  sajungRateRange     Json         // { min, max, p25, p75 }
  sampleSize          Int
  optimalBidPrice     BigInt
  bidPriceRangeLow    BigInt
  bidPriceRangeHigh   BigInt
  lowerLimitPrice     BigInt
  winProbability      Float
  competitionScore    Int
  expectedBidders     Int
  dominantCompany     String?
  dominantWinRate     Float?
  modelVersion        String
  expiresAt           DateTime     // 24시간 캐시
  createdAt           DateTime     @default(now())

  @@index([annId, expiresAt])
}

model AIPrediction {
  id                   String    @id @default(cuid())
  annId                String    @unique
  konepsId             String
  title                String
  orgName              String
  deadline             DateTime
  budget               BigInt    @default(0)

  // AI 예측값
  predictedSajungRate  Decimal   @db.Decimal(10, 4)
  optimalBidPrice      BigInt
  lowerLimitRate       Decimal   @db.Decimal(10, 4) @default(0)
  winProbability       Int       @default(0)
  competitionScore     Int       @default(0)
  predictedAt          DateTime  @default(now())

  // 실제 결과 (개찰 후 채워짐)
  actualSajungRate     Decimal?  @db.Decimal(10, 4)
  actualFinalPrice     BigInt?
  actualBidRate        Decimal?  @db.Decimal(10, 4)
  resultFilledAt       DateTime?

  // 적중 여부
  deviationPct         Decimal?  @db.Decimal(10, 4)
  isHit                Boolean?
  isNearHit            Boolean?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([annId])
  @@index([konepsId])
  @@index([deadline])
  @@index([isHit])
  @@index([predictedAt])
}

model CompetitorProfile {
  id            String   @id @default(cuid())
  companyName   String
  category      String
  region        String
  avgSajungRate Float
  sajungRateStd Float
  bidStyle      String   // "conservative" | "aggressive" | "balanced"
  winRate       Float
  sampleSize    Int
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([companyName, category, region])
  @@index([category, region])
}

model WinProbSimulation {
  id          String   @id @default(cuid())
  userId      String
  annId       String
  inputPrice  BigInt
  inputSajung Float
  probability Float
  createdAt   DateTime @default(now())

  @@index([userId, annId])
}

enum Plan {
  FREE
  STANDARD
  PRO
}

enum SubStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum CrawlType {
  ANNOUNCEMENT
  BID_RESULT
  HIST_CURSOR
}

enum CrawlStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model BetaApplication {
  id        String     @id @default(cuid())
  bizNo     String     @unique
  bizName   String
  email     String
  category  String
  status    BetaStatus @default(PENDING)
  createdAt DateTime   @default(now())
}

enum OutcomeResult {
  WIN
  LOSE
  DISQUALIFIED
  PENDING
}

enum BetaStatus {
  PENDING
  APPROVED
  REJECTED
}

model SajungAnalysisCache {
  id         String   @id @default(cuid())
  annId      String
  period     String   // "1y" | "2y" | "3y" | "all"
  cacheType  String   // "histogram" | "trend" | "topten"
  userId     String   @default("") // trend는 userId 포함, 나머지는 ""
  result     Json
  sampleSize Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([annId, period, cacheType, userId])
}
