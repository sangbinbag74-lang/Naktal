# Supabase
NEXT_PUBLIC_SUPABASE_URL=        # 프로젝트 URL (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # anon public key
SUPABASE_SERVICE_ROLE_KEY=       # service_role (서버 전용, NEXT_PUBLIC_ 금지)

# Prisma (Supabase PostgreSQL)
DATABASE_URL=                    # 풀링 커넥션 (Transaction mode) - Prisma용
DIRECT_URL=                      # 다이렉트 커넥션 - 마이그레이션용

# 관리자 API (Step 2)
ADMIN_SECRET_KEY=                # POST /api/admin/crawl 보호용 시크릿

# 포트원 v2 (Step 3에서 실제 사용)
NEXT_PUBLIC_PORTONE_STORE_ID=    # 포트원 콘솔 > 상점 ID
NEXT_PUBLIC_PORTONE_CHANNEL_KEY= # 결제 채널 키
PORTONE_SECRET_KEY=              # API Secret (서버 전용, NEXT_PUBLIC_ 절대 금지)
PORTONE_WEBHOOK_SECRET=          # 웹훅 서명 검증용 시크릿

# 국세청 NTS API (Step 3)
NTS_API_KEY=                     # data.go.kr 서비스 키 (사업자번호 검증)

# 이메일 알림 (Step 3)
RESEND_API_KEY=                  # Resend API 키

# 사이트 URL (Step 3 - 비밀번호 재설정 리다이렉트 등)
NEXT_PUBLIC_SITE_URL=            # https://naktal.me

# ML API (Step 4 - Modal.com 배포 후 발급)
ML_API_URL=                      # https://xxx--naktal-ml-fastapi-app.modal.run
ML_API_KEY=                      # 32자+ 랜덤 문자열 (직접 생성)
